FROM maven:3.9.6-eclipse-temurin-17 AS development

RUN apt-get update && apt-get install -y mariadb-client git && rm -rf /var/lib/apt/lists/*

# Standardize commands via scripts
RUN echo '#!/bin/bash\nmvn compile' > /usr/local/bin/agent-build && chmod +x /usr/local/bin/agent-build
RUN echo '#!/bin/bash\nmvn test' > /usr/local/bin/agent-test && chmod +x /usr/local/bin/agent-test

WORKDIR /workspace
CMD ["tail", "-f", "/dev/null"]